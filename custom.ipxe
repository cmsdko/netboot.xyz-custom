#!ipxe

set proxmox_version 8.4-1
set iso_url http://download.proxmox.com/iso/proxmox-ve_${proxmox_version}.iso
set pve_opts vga=791 video=vesafb:ywrap,mtrr ramdisk_size=16777216 rw quiet

kernel ${iso_url} /boot/linux26 ${pve_opts} splash=silent
initrd ${iso_url} /boot/initrd.img
initrd ${iso_url} /proxmox.iso
boot

